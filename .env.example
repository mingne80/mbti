# 로컬 테스트 기본값입니다. 이 상태에서는 브라우저 localStorage를 DB처럼 사용합니다.
NEXT_PUBLIC_STORAGE_MODE=local

# 관리자 삭제 기능 비밀번호입니다. 배포 시 Vercel 환경변수에도 같은 키로 등록하세요.
ADMIN_PASSWORD=rhksflwk01!

# 배포 시:
# 1. NEXT_PUBLIC_STORAGE_MODE=postgres 로 설정
# 2. Neon, Supabase, Vercel Postgres 같은 무료 Postgres의 접속 문자열을 넣습니다.
# DATABASE_URL=postgres://USER:PASSWORD@HOST:PORT/DB?sslmode=require
